# ── Supabase ──────────────────────────────────────────────────────────────
# URL del proyecto (Settings > API)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Service Role Key — NUNCA exponer en el frontend (solo Vercel functions)
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Admin Panel ───────────────────────────────────────────────────────────
# Clave secreta para el panel /admin.html
# Generar con: openssl rand -hex 32
ADMIN_KEY=cambia_esto_por_una_clave_segura

# ── WhatsApp Bot (Meta Cloud API) ─────────────────────────────────────────
# Token permanente del System User (Meta Business → System Users)
WA_TOKEN=EAAxxxxxxx...

# ID del número de WhatsApp Business (Meta Developers → WhatsApp → Phone numbers)
WA_PHONE_NUMBER_ID=1234567890

# Token de verificación del webhook (tú lo inventas, debe coincidir con Meta)
WA_VERIFY_TOKEN=ucars_webhook_2026

# Número humano al que el bot deriva cuando el cliente quiere hablar con alguien
WA_HUMAN_NUMBER=56974992231

# ── n8n (notificación al Ucariano cuando hay lead de visita) ──────────────
# URL del webhook en tu n8n local o cloud
# Recibe JSON: { tipo, auto, precio, vendedor_nombre, vendedor_telefono,
#               prospecto_nombre, prospecto_whatsapp, disponibilidad }
N8N_WEBHOOK_URL=https://tu-n8n.com/webhook/ucars-lead
